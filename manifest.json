{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "description": "__MSG_extDescription__",
  "version": "1.0.2",
  "default_locale": "ja",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "__MSG_extName__"
  },
  "permissions": [
    "activeTab",
    "downloads",
    "storage",
    "unlimitedStorage",
    "contextMenus",
    "scripting",
    "debugger",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "scripts/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["scripts/content.js"],
      "css": ["scripts/content.css"],
      "run_at": "document_end"
    }
  ],
  "options_page": "options/options.html",
  "commands": {
    "capture-full-page": {
      "suggested_key": {
        "default": "Alt+Shift+S",
        "mac": "Alt+Shift+S"
      },
      "description": "__MSG_cmdCaptureFullPage__"
    },
    "capture-selection": {
      "suggested_key": {
        "default": "Alt+Shift+A",
        "mac": "Alt+Shift+A"
      },
      "description": "__MSG_cmdCaptureSelection__"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["editor/editor.html", "editor/editor.css", "editor/editor.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
